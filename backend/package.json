{
  "name": "odoo-finals",
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "generate": "prisma generate --schema=src/prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "db:prepare": "npm run migrate:deploy && npm run generate",
    "seed": "node src/prisma/seed.js",
    "seed:full": "npm run db:prepare && npm run seed",
    "seed:push": "npm run generate && npx prisma db push --schema=src/prisma/schema.prisma && npm run seed"
  },
  "prisma": {
    "seed": "node src/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.3",
    "prisma": "^6.0.0",
    "redis": "^5.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
