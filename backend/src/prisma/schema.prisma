generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER MANAGEMENT ---

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?
  role     Role    @default(ENGINEER)

  // Named relation to match the ECO model below
  ecos ECO[]      @relation("UserToECO")
  logs AuditLog[]
  passwordResetOtps PasswordResetOtp[]
  ecoApprovalRules EcoApprovalRule[]
}

enum EcoPipelineKind {
  NONE
  DRAFT_SET
  NEW
  PENDING
  TERMINAL
}

model EcoStage {
  id           String            @id @default(uuid())
  name         String
  sortOrder    Int
  pipelineKind EcoPipelineKind   @default(NONE)
  createdAt    DateTime          @default(now())
  approvalRules EcoApprovalRule[]
}

model EcoApprovalRule {
  id        String   @id @default(uuid())
  stageId   String
  stage     EcoStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  scopeKey  String   @default("GLOBAL")
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([stageId, userId, scopeKey])
}

model PasswordResetOtp {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otpHash   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Role {
  ENGINEER
  APPROVER
  ADMIN
}

// --- PRODUCT & VERSIONING ---

model Product {
  id                String            @id @default(uuid())
  sku               String            @unique
  name              String
  versions          ProductVersion[]
  boms              BillOfMaterial[]
  ecos              ECO[]
  ecoApprovalRules  EcoApprovalRule[]
  createdAt         DateTime          @default(now())
}

model ProductVersion {
  id            String   @id @default(uuid())
  versionNumber Int
  salePrice     Float
  costPrice     Float
  status        String   @default("ACTIVE") // "ACTIVE", "ARCHIVED"
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  createdAt     DateTime @default(now())
}

// --- BILL OF MATERIALS ---

model BillOfMaterial {
  id            String         @id @default(uuid())
  versionNumber Int            @default(1)
  status        String         @default("ACTIVE") // ACTIVE, ARCHIVED
  productId     String
  product       Product        @relation(fields: [productId], references: [id])
  components    BoMComponent[]
  createdAt     DateTime       @default(now())
}

model BoMComponent {
  id            String         @id @default(uuid())
  bomId         String
  bom           BillOfMaterial @relation(fields: [bomId], references: [id])
  componentName String
  quantity      Int
}

// --- CHANGE MANAGEMENT (ECO) ---

model ECO {
  id              String @id @default(uuid())
  title           String
  type            String // "PRODUCT", "BOM"
  status          String @default("NEW") // "NEW", "PENDING", "APPROVED", "REJECTED"
  proposedChanges Json

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdById String
  // This must match the name in the User model
  createdBy   User   @relation("UserToECO", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

// --- AUDIT & TRACEABILITY ---

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  targetId  String
  oldValue  Json?
  newValue  Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  timestamp DateTime @default(now())
}
